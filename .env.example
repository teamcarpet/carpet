# Solana RPC endpoint (mainnet)
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Pinata IPFS credentials (https://pinata.cloud)
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# LiveKit credentials (https://livekit.io)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_LIVEKIT_API_KEY=your_api_key_here

# LiveKit server-side secret (used by server/index.js only — never expose to browser)
LIVEKIT_API_SECRET=your_api_secret_here

# Platform WebSocket server URL (run server/index.js)
VITE_WS_SERVER_URL=ws://localhost:3001

# Jupiter API base URL (public, no key required)
VITE_JUPITER_API_URL=https://quote-api.jup.ag/v6

# Platform config
VITE_PLATFORM_NAME=CARPET
VITE_PLATFORM_FEE_BPS=100
# Wallet address that collects platform fees
VITE_FEE_WALLET=your_fee_wallet_pubkey_here
