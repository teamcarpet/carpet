# ─────────────────────────────────────────────────────────────────────────
# CARPET BACKEND — env template
# Copy this to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Solana ───────────────────────────────────────────────────────────────
# Network the indexer subscribes to. Change to "mainnet" when contract is on mainnet.
SOLANA_CLUSTER=devnet

# CARPET program ID (same on devnet and mainnet)
PROGRAM_ID=DywpVp5YfLiX4M3xfEp333Y2dmq8xywdNAYaWDw6v9XV

# Standard RPC endpoint (used by API for direct chain reads where needed)
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Yellowstone gRPC (Constant Kaldera) ──────────────────────────────────
# Use grpcs:// for TLS (port 443). For mainnet use the same endpoint —
# Yellowstone serves devnet+mainnet from the same gRPC server.
GEYSER_ENDPOINT=https://kaldera-frankfurt.constant-k.com/
GEYSER_X_TOKEN=replace_me_after_token_rotation

# ── Database ─────────────────────────────────────────────────────────────
# Local docker-compose: postgres://carpet:carpet@localhost:5432/carpet
# Railway: filled in automatically by the Postgres plugin
DATABASE_URL=postgres://carpet:carpet@localhost:5432/carpet

# ── Redis ────────────────────────────────────────────────────────────────
# Local docker-compose: redis://localhost:6379
# Railway: filled in automatically by the Redis plugin
REDIS_URL=redis://localhost:6379

# ── Service ports ────────────────────────────────────────────────────────
API_PORT=3000
WS_PORT=3001

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Indexer behaviour ────────────────────────────────────────────────────
# When MOCK_MODE=true, indexer ignores Geyser and emits fake events every
# few seconds. Useful for local pipeline testing without real chain data.
MOCK_MODE=true
MOCK_INTERVAL_MS=5000
