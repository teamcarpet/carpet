{
  "name": "@carpet/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":        { "types": "./dist/index.d.ts",     "default": "./dist/index.js" },
    "./db":     { "types": "./dist/db/client.d.ts", "default": "./dist/db/client.js" },
    "./schema": { "types": "./dist/db/schema.d.ts", "default": "./dist/db/schema.js" },
    "./env":    { "types": "./dist/env.d.ts",       "default": "./dist/env.js" },
    "./logger": { "types": "./dist/logger.d.ts",    "default": "./dist/logger.js" },
    "./redis":  { "types": "./dist/redis.d.ts",     "default": "./dist/redis.js" },
    "./types":  { "types": "./dist/types.d.ts",     "default": "./dist/types.js" }
  },
  "scripts": {
    "build":       "tsc",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate":  "tsx src/db/migrate.ts",
    "db:push":     "drizzle-kit push --config drizzle.config.ts"
  },
  "dependencies": {
    "dotenv":      "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "ioredis":     "^5.4.1",
    "pino":        "^9.5.0",
    "pino-pretty": "^11.2.2",
    "postgres":    "^3.4.5",
    "zod":         "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "drizzle-kit": "^0.28.0",
    "tsx":         "^4.19.0",
    "typescript":  "^5.6.3"
  }
}